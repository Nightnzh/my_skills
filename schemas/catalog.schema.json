{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/catalog.schema.json",
  "title": "Skill Catalog",
  "type": "object",
  "required": ["generated_at", "skills"],
  "properties": {
    "generated_at": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "skill.schema.json"
      }
    }
  },
  "additionalProperties": false
}
