{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/skill.schema.json",
  "title": "Skill Metadata",
  "type": "object",
  "required": [
    "slug",
    "name",
    "version",
    "summary",
    "description",
    "authors",
    "tags",
    "platforms",
    "install",
    "entrypoint",
    "compatibility",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "install": {
      "type": "object",
      "required": ["method"],
      "properties": {
        "method": { "enum": ["script", "git"] }
      },
      "additionalProperties": true
    },
    "entrypoint": { "type": "string" },
    "compatibility": { "type": "object" },
    "status": { "enum": ["active", "experimental", "deprecated"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provides": {
      "type": "array",
      "items": { "type": "string" }
    },
    "examples": {
      "type": "array",
      "items": { "type": "object" }
    },
    "repository": { "type": "string" },
    "homepage": { "type": "string" },
    "deprecation": { "type": "object" },
    "assets": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
